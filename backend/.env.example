# Google Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub personal access token — for repo context fetching (optional but recommended)
GITHUB_TOKEN=your_github_token_here

# Allowed CORS origin — your frontend URL (Vercel URL in production)
ALLOWED_ORIGIN=http://localhost:5500

# Server port
PORT=3000

# Admin password for /admin/logs endpoint — REQUIRED, no default for security
ADMIN_PASSWORD=your_secret_password_here
